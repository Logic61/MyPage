---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout title="Shane Lorien - 首页">
  <main class="max-w-4xl mx-auto p-12 bg-white font-sans text-slate-900 leading-relaxed dark:bg-slate-950 dark:text-slate-100 transition-colors duration-300">
    <Navigation />

    <header class="flex justify-between items-start mb-20">
      <div class="space-y-4">
        <h1 class="text-6xl font-extrabold tracking-tighter text-slate-900 dark:text-slate-100">Shane Lorien</h1>
        <p class="text-xl text-slate-500 font-medium dark:text-slate-400">北京大学 · 信息科学技术学院 · 计算机类</p>
      </div>

      <div class="flex-shrink-0">
        <img src="/avatar.jpg" alt="Avatar" class="w-28 h-28 rounded-full border border-slate-100 shadow-sm object-cover dark:border-slate-800" />
      </div>
    </header>

    <div class="space-y-24">
      <!-- About Section -->
      <section class="grid grid-cols-[140px,1fr] gap-8 items-start">
        <h2 class="text-sm font-semibold tracking-widest text-slate-400 uppercase mt-1">关于我</h2>
        <div class="space-y-4 text-slate-700 dark:text-slate-300">
          <p>
            你好，我是Shane Lorien，是北大信科计算机类的一名大一学生。
          </p>
          <p>
            目前兴趣仍并没有十分确定的方向，正在探索之中。
			除了专业方向外，对钢琴、写作、导引等方面也有一定兴趣，
			关于这方面内容，可以在我的生活向blog 
			<a href="https://logic61.github.io/" class="text-blue-600 dark:text-blue-400 hover:underline">https://logic61.github.io/</a> 
			中找到一些相关的记录和思考。
          </p>
        </div>
      </section>

      <!-- Education Section -->
      <section class="grid grid-cols-[140px,1fr] gap-8 items-start">
        <h2 class="text-sm font-semibold tracking-widest text-slate-400 uppercase mt-1">教育背景</h2>
        <div>
          <div class="flex items-center justify-between mb-1">
            <h3 class="font-medium text-slate-900 dark:text-slate-100">北京大学</h3>
            <span class="text-sm text-slate-500 dark:text-slate-400">2025 - 至今</span>
          </div>
          <p class="text-slate-600 mb-2 dark:text-slate-300">信息科学技术学院</p>
          <p class="text-sm text-slate-500 dark:text-slate-400">计算机类 本科在读</p>
          <p class="text-sm text-slate-400 mt-2 dark:text-slate-500">相关课程：高等数学，线性代数，计算概论等</p>
        </div>
      </section>

      <!-- Skills Section -->
      <section class="grid grid-cols-[140px,1fr] gap-8 items-start">
        <h2 class="text-sm font-semibold tracking-widest text-slate-400 uppercase mt-1">专业技能</h2>
        <div class="grid grid-cols-2 gap-y-6 gap-x-4 text-sm">
          <div>
            <h3 class="font-medium text-slate-900 mb-2">编程语言</h3>
            <p class="text-slate-600 flex flex-wrap gap-2">
              <span class="px-2 py-1 bg-slate-50 rounded text-slate-600">C++</span>
              <span class="px-2 py-1 bg-slate-50 rounded text-slate-600">Python</span>
            </p>
          </div>

          <div class="col-span-2">
            <h3 class="font-medium text-slate-900 mb-2">工具与其他</h3>
            <p class="text-slate-600 flex flex-wrap gap-2">
              <span class="px-2 py-1 bg-slate-50 rounded text-slate-600">Git / GitHub</span>
              <span class="px-2 py-1 bg-slate-50 rounded text-slate-600">Latex</span>
              <span class="px-2 py-1 bg-slate-50 rounded text-slate-600">Markdown</span>
            </p>
          </div>
        </div>
      </section>

      <!-- Projects Section -->
      <section class="grid grid-cols-[140px,1fr] gap-8 items-start">
        <h2 class="text-sm font-semibold tracking-widest text-slate-400 uppercase mt-1">精选项目</h2>
        <div class="space-y-10">
          <div class="group">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-medium text-slate-900 dark:text-slate-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                <a href="https://github.com/Logic61/AmazonChess" target="_blank" rel="noopener noreferrer">AmazonChess</a>
              </h3>
              <span class="text-xs font-mono text-slate-500 dark:text-slate-400 bg-slate-50 dark:bg-slate-900/50 px-2 py-1 rounded">C++</span>
            </div>
            <p class="text-slate-600 dark:text-slate-300 text-sm mb-3">北京大学计算概论A 2025秋大作业：亚马逊棋</p>
            <ul class="text-sm text-slate-500 dark:text-slate-400 space-y-1.5 list-disc list-inside">
              <li>实现基础棋盘逻辑、合法落子判定与障碍物检测</li>
              <li>使用 C++ 编写核心博弈逻辑框架</li>
              <li>良好的代码组织与模块化实现</li>
            </ul>
          </div>

          <div class="group">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-medium text-slate-900 dark:text-slate-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                <a href="https://github.com/Logic61/Obsidian-to-Hexo" target="_blank" rel="noopener noreferrer">Obsidian-to-Hexo</a>
              </h3>
              <span class="text-xs font-mono text-slate-500 dark:text-slate-400 bg-slate-50 dark:bg-slate-900/50 px-2 py-1 rounded">Python</span>
            </div>
            <p class="text-slate-600 dark:text-slate-300 text-sm mb-3">将 Obsidian 的 Markdown 笔记迁移至 Hexo 博客的自动化工具</p>
            <ul class="text-sm text-slate-500 dark:text-slate-400 space-y-1.5 list-disc list-inside">
              <li>解析并转换 Obsidian 特有语法的 Markdown 文档</li>
              <li>自动适配与转移到 Hexo 的 posts 目录，并整理元数据</li>
              <li>由 Python 编写以实现批量无缝备份与发布</li>
            </ul>
          </div>
        </div>
      </section>

	  <!-- Hobbies & Skills Section -->
      <section class="grid grid-cols-[140px,1fr] gap-8 items-start">
        <h2 class="text-sm font-semibold tracking-widest text-slate-400 dark:text-slate-500 uppercase mt-1">业余技能</h2>
        <div class="space-y-6">
          
          <div class="group">
            <h3 class="font-medium text-slate-900 dark:text-slate-100 mb-2">钢琴（列一点谈过的肖邦吧)</h3>
            <ul class="text-sm text-slate-600 dark:text-slate-300 space-y-1.5 list-none">
              <li><span class="text-slate-500 dark:text-slate-400 mr-2">练习曲：</span>Op. 10 No. 1, 2, 4, 5, 8 <span class="mx-1 text-slate-300 dark:text-slate-600">|</span> Op. 25 No. 5, 6, 9, 11</li>
              <li><span class="text-slate-500 dark:text-slate-400 mr-2">叙事曲：</span>No. 1, 3</li>
              <li><span class="text-slate-500 dark:text-slate-400 mr-2">谐谑曲：</span>No. 2</li>
			  <li><span class="text-slate-500 dark:text-slate-400 mr-2">夜曲：</span>op.9 no.1,2</li>
			  <li><span class="text-slate-500 dark:text-slate-400 mr-2">大波兰 </span>op.22</li>
			</ul>
          </div>

          <div class="group">
            <h3 class="font-medium text-slate-900 dark:text-slate-100 mb-2">导引</h3>
            <div class="flex flex-wrap gap-2 text-sm text-slate-600 dark:text-slate-300">
              <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 rounded text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700">五段锦</span>
              <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 rounded text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700">五禽戏</span>
              <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 rounded text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700">长寿功</span>
              <span class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 rounded text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700">八部金刚功</span>
            </div>
          </div>

        </div>
      </section>
    </div>

  </main>
</Layout>
